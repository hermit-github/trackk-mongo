{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Express API",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "ts-node-dev",
        "--respawn",
        "--inspect",
        "--transpile-only",
        "src/server.ts"
      ],
      "cwd": "${workspaceFolder}",
      "restart": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}